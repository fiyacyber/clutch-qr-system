+  .clutch-qr-page__hero,
+  .clutch-reach-out,
+  .clutch-home-reach-out,
+  .clutch-business-kits,
+  .clutch-business-kits-collection,
+  .clutch-footer {
+    padding-inline: max(0.9rem, var(--page-margin));
+  }
+
+  /* Header/logo/menu fit adjustments */
+  .header,
+  .header__columns,
+  .header__row {
+    max-width: 100%;
+  }
+
+  .header__heading-logo {
+    height: auto;
+    max-height: 36px;
+    width: auto;
+  }
+
+  .menu-drawer__menu-item,
+  .menu-drawer__menu-item-text {
+    white-space: normal;
+  }
+
+  /* Contact areas and forms readability */
+  .clutch-home-reach-out__details,
+  .clutch-reach-out__details,
+  .clutch-footer__contact {
+    justify-items: center;
+  }
+
+  input,
+  select,
+  textarea,
+  button,
+  .button,
+  .button-secondary {
+    min-height: 44px;
+  }
+}
+
+@media screen and (max-width: 768px) {
+  /* Card stacks and compact spacing */
+  .ch-kits__grid,
+  .ch-essentials__grid,
+  .clutch-business-kits__grid,
+  .clutch-business-kits-collection__grid,
+  .clutch-qr-page__pricing-grid,
+  .clutch-qr-page__card-grid,
+  .clutch-qr-trust__grid {
+    gap: 0.9rem;
+    grid-template-columns: 1fr;
+  }
+
+  /* Keep some product grids at 2 columns where space allows */
+  .product-grid {
+    --mobile-columns: 2;
+  }
+
+  /* Buttons full width on mobile where needed */
+  .ch-hero__actions .ch-btn,
+  .ch-kits .ch-kit-card__button,
+  .clutch-business-kits .clutch-kit-card__button,
+  .clutch-business-kits-collection .clutch-shop-card--kit-button,
+  .clutch-qr-page__actions .button,
+  .clutch-qr-page__actions .button-secondary,
+  .clutch-qr-page__pricing-grid .button,
+  .clutch-reach-out .button,
+  .clutch-home-reach-out .button,
+  .clutch-business-kits__custom .button,
+  .clutch-business-kits-collection__custom .button {
+    width: 100%;
+  }
+
+  /* Hero and card padding reductions */
+  .ch-hero,
+  .clutch-qr-page__hero {
+    padding-block: clamp(2.5rem, 7vw, 3.5rem);
+  }
+
+  .ch-hero__inner,
+  .clutch-qr-page__hero-inner,
+  .clutch-reach-out__card,
+  .clutch-home-reach-out__inner,
+  .clutch-business-kits-collection .clutch-shop-card--kit-body,
+  .clutch-business-kits .clutch-kit-card__body,
+  .ch-kit-card__body {
+    padding: 1.1rem;
+  }
+
+  .clutch-footer__inner,
+  .clutch-footer__bottom {
+    text-align: center;
+  }
+}
+
+@media screen and (max-width: 480px) {
+  /* Single-column fallback for very small screens */
+  .product-grid,
+  .ch-essentials__grid,
+  .ch-kits__grid,
+  .clutch-business-kits__grid,
+  .clutch-business-kits-collection__grid,
+  .clutch-qr-page__card-grid,
+  .clutch-qr-page__pricing-grid {
+    --mobile-columns: 1;
+    grid-template-columns: 1fr;
+  }
+
+  .header__heading-logo {
+    max-height: 32px;
+  }
+
+  .clutch-footer p,
+  .clutch-footer a,
+  .clutch-footer li,
+  .clutch-home-reach-out__details span,
+  .clutch-reach-out__value {
+    font-size: clamp(0.92rem, 3.6vw, 1rem);
+  }
+}
+
+main[data-template^='product'] > .shopify-section[id$='__product_options'] {
+  display: none !important;
+}
+
+.clutch-business-cards-nav {
+  position: relative;
+}
+
+.clutch-business-cards-nav__submenu {
+  background: #fff;
+  border: 1px solid rgba(255, 166, 101, 0.32);
+  border-radius: 16px;
+  box-shadow: 0 20px 45px rgba(56, 72, 98, 0.16);
+  display: grid;
+  gap: 0.25rem;
+  left: 50%;
+  min-width: 240px;
+  opacity: 0;
+  padding: 0.7rem;
+  pointer-events: none;
+  position: absolute;
+  top: calc(100% + 0.75rem);
+  transform: translateX(-50%) translateY(-8px);
+  transition: opacity 0.16s ease, transform 0.16s ease;
+  z-index: 40;
+}
+
+.clutch-business-cards-nav:hover .clutch-business-cards-nav__submenu,
+.clutch-business-cards-nav:focus-within .clutch-business-cards-nav__submenu {
+  opacity: 1;
+  pointer-events: auto;
+  transform: translateX(-50%) translateY(0);
+}
+
+.clutch-business-cards-nav__submenu a,
+.clutch-business-cards-drawer__list a {
+  border-radius: 10px;
+  color: #384862;
+  display: block;
+  font-weight: 850;
+  padding: 0.75rem 0.85rem;
+  text-decoration: none;
+}
+
+.clutch-business-cards-nav__submenu a:hover,
+.clutch-business-cards-drawer__list a:hover {
+  background: rgba(255, 166, 101, 0.14);
+}
+
+.clutch-business-cards-drawer summary {
+  cursor: pointer;
+}
+
+.clutch-business-cards-drawer__list {
+  display: grid;
+  gap: 0.25rem;
+  padding: 0.25rem 0 0.75rem 1rem;
+}
