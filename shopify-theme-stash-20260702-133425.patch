+  min-width: 0;
+}
+
+@media screen and (max-width: 990px) {
+  /* Product / collection density and wrapping */
+  .product-grid {
+    --mobile-columns: 2;
+  }
+
+  .clutch-shop-card__body p {
+    overflow: visible;
+    text-overflow: clip;
+    white-space: normal;
+  }
+
+  /* Reduce oversized desktop spacing in hero-like sections */
