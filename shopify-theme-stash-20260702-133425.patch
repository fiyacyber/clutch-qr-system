+    padding: clamp(2.5rem, 6vw, 4.5rem) var(--page-margin);
+    width: 100%;
+  }
+
+  .collection-wrapper--clutch-business-kits {
+    display: block;
+    width: 100%;
+  }
+
+  body:has(.collection-wrapper--clutch-business-kits) main > .shopify-section:first-of-type {
+    display: none;
+  }
+
+  .clutch-business-kits-collection__intro {
+    margin: 0 auto clamp(1.5rem, 4vw, 2.35rem);
+    max-width: 820px;
+    text-align: center;
+  }
+
+  .clutch-business-kits-collection__intro h2 {
+    color: #384862;
+    font-family: 'Exo 2', sans-serif;
+    font-size: clamp(2rem, 6vw, 3.5rem);
+    line-height: 1;
+    margin: 0.6rem 0 1rem;
+  }
+
+  .clutch-business-kits-collection__intro p:not(.clutch-eyebrow) {
+    color: rgba(56, 72, 98, 0.82);
+    font-family: 'Montserrat', sans-serif;
+    font-size: clamp(1rem, 2.5vw, 1.08rem);
+    line-height: 1.6;
+    margin: 0;
+  }
+
+  .clutch-business-kits-collection__highlight {
+    color: #ffa665;
+    font-weight: 800;
+  }
+
+  .clutch-business-kits-collection__grid {
+    display: grid;
+    gap: clamp(1rem, 2vw, 1.5rem);
+    grid-template-columns: 1fr;
+  }
+
+  .clutch-business-kits-collection__custom,
+  .clutch-business-kits-collection__empty {
+    font-family: 'Montserrat', sans-serif;
+    text-align: center;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit {
+    background: #fff;
+    border: 1px solid rgba(56, 72, 98, 0.14);
+    border-radius: 22px;
+    box-shadow: 0 16px 40px rgba(56, 72, 98, 0.08);
+    display: flex;
+    min-height: 405px;
+    width: 100%;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit.clutch-shop-card--kit-featured {
+    background: #fff7f0;
+    border-color: rgba(255, 166, 101, 0.65);
+    box-shadow: 0 22px 48px rgba(255, 166, 101, 0.18);
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-body {
+    align-items: stretch;
+    display: flex;
+    flex-direction: column;
+    flex-grow: 1;
+    padding: clamp(1.35rem, 3vw, 1.7rem);
+    text-align: center;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-flag {
+    align-self: center;
+    background: #384862;
+    border-radius: 999px;
+    box-shadow: 0 12px 24px rgba(56, 72, 98, 0.18);
+    color: #fff;
+    display: inline-block;
+    font-size: 0.7rem;
+    font-weight: 800;
+    letter-spacing: 0.08em;
+    margin: 0 0 0.85rem;
+    padding: 0.4rem 0.75rem;
+    text-transform: uppercase;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-label {
+    color: #ffa665;
+    font-family: 'Montserrat', sans-serif;
+    font-size: 0.78rem;
+    font-weight: 800;
+    letter-spacing: 0.12em;
+    line-height: 1.2;
+    margin: 0 0 0.7rem;
+    text-transform: uppercase;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-title {
+    color: #384862;
+    font-family: 'Exo 2', sans-serif;
+    font-size: clamp(1.45rem, 3vw, 1.95rem);
+    line-height: 1.08;
+    margin: 0 0 1rem;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-features {
+    display: grid;
+    align-content: start;
+    flex: 1 1 auto;
+    gap: 0.5rem;
+    list-style: none;
+    margin: 0;
+    padding: 0;
+    text-align: left;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-features li {
+    align-items: flex-start;
+    background: #f6f8fb;
+    border: 1px solid rgba(56, 72, 98, 0.08);
+    border-radius: 12px;
+    color: rgba(56, 72, 98, 0.92);
+    display: grid;
+    font-size: 0.93rem;
+    gap: 0.7rem;
+    grid-template-columns: 18px 1fr;
+    line-height: 1.45;
+    padding: 0.62rem 0.78rem;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-featured .clutch-shop-card--kit-features li {
+    background: rgba(255, 166, 101, 0.08);
+    border-color: rgba(255, 166, 101, 0.18);
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-features li::before {
+    color: #ffa665;
+    content: '✓';
+    font-size: 0.9rem;
+    font-weight: 900;
+    line-height: 1.45;
+    text-align: center;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-feature-row-highlight {
+    color: #f39d64;
+    font-weight: 700;
+  }
+
+  .clutch-business-kits-collection .clutch-shop-card--kit-button {
+    background: #ffa665 !important;
+    color: #384862 !important;
+    margin-top: 1.2rem;
+    min-height: 48px;
+    width: 100%;
+  }
+
+  .clutch-business-kits-collection__empty {
+    background: #fff;
+    border: 1px solid rgba(56, 72, 98, 0.14);
+    border-radius: 22px;
+    box-shadow: 0 14px 38px rgba(56, 72, 98, 0.08);
+    color: #384862;
+    display: grid;
+    gap: 1rem;
+    margin-inline: auto;
+    max-width: 720px;
+    padding: clamp(1.5rem, 4vw, 2.5rem);
+  }
+
+  .clutch-business-kits-collection__empty p {
+    font-size: 1rem;
+    line-height: 1.6;
+    margin: 0;
+  }
+
+  .clutch-business-kits-collection__custom {
+    align-items: center;
+    display: flex;
+    flex-direction: column;
+    gap: 1rem;
+    margin-top: clamp(1.75rem, 4vw, 2.5rem);
+  }
+
+  .clutch-business-kits-collection__custom p {
+    color: #384862;
+    font-family: 'Exo 2', sans-serif;
+    font-size: clamp(1.3rem, 4vw, 1.8rem);
+    font-weight: 800;
+    line-height: 1.1;
+    margin: 0;
+  }
+
+  .clutch-business-kits-collection__custom .button,
+  .clutch-business-kits-collection__empty .button {
+    background: #384862 !important;
+    color: #fff !important;
+  }
+
+  @media screen and (min-width: 750px) {
+    .clutch-business-kits-collection__grid {
+      grid-template-columns: repeat(3, minmax(0, 1fr));
+    }
+  }
+{% endstylesheet %}
