+
+/* ====================================================
+   MOBILE RESPONSIVE AUDIT PATCH
+   Scope: homepage, business kits, product/collection,
+   QR Pro, reach-out/contact, header/footer
+==================================================== */
+html,
+body {
+  max-width: 100%;
+  overflow-x: clip;
+}
+
+/* Keep long strings from blowing out cards/forms/menus */
+a,
+button,
+input,
+label,
+li,
+span,
+summary,
+textarea {
+  overflow-wrap: break-word;
+}
+
+/* Defensive media scaling */
+img,
+svg,
+video,
+canvas,
+iframe {
+  height: auto;
+  max-width: 100%;
+}
+
+/* Keep homepage Business Kit QR text aligned with the feature text column. */
+.ch-kits .ch-kit-card__features > li > .ch-kit-card__feature-highlight {
+  display: block;
+  grid-column: 2;
+}
+
+/* Prevent flex/grid children from causing horizontal scroll */
+.grid > *,
+.main-collection-grid > *,
+.product-grid > *,
+.ch-kits__grid > *,
+.ch-essentials__grid > *,
+.clutch-business-kits__grid > *,
+.clutch-business-kits-collection__grid > *,
